<!DOCTYPE hibernate-configuration PUBLIC
 "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
 "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="connection.driver_class">
            oracle.jdbc.OracleDriver
        </property>

        <property name="connection.url">
            jdbc:oracle:thin:@//localhost:1522/orclpdb
        </property>

        <property name="connection.username">hr</property>
        <property name="connection.password">hr</property>

        <property name="dialect">
            org.hibernate.dialect.Oracle12cDialect
        </property>

        <property name="current_session_context_class">
            thread
        </property>

        <property name="hbm2ddl.auto">
            create
        </property>

        <property name="show_sql">
            true
        </property>

        <mapping class="com.hibernate.model.User"/>
        <mapping class="com.hibernate.model.UserDetails"/>
        <mapping class="com.hibernate.model.Friend"/>
        <mapping class="com.hibernate.model.Post"/>
<mapping class="com.hibernate.model.StudentUser"/>

    </session-factory>
</hibernate-configuration>